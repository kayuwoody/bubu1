# Supabase — get from Project Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Fiuu — get from Fiuu merchant portal
FIUU_MERCHANT_ID=your_merchant_id
FIUU_VERIFY_KEY=your_verify_key
FIUU_SECRET_KEY=your_secret_key
# Sandbox: https://sandbox.merchant.razer.com  Production: https://pay.fiuu.com
FIUU_BASE_URL=https://sandbox.merchant.razer.com

# Base URL — used to build returnurl / callbackurl for Fiuu
# On Vercel this is set automatically as VERCEL_URL (no https://)
# Set this explicitly for local dev or non-Vercel deployments
NEXT_PUBLIC_BASE_URL=https://your-site.vercel.app
